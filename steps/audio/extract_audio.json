{
  "name": "extract_audio",
  "description": "Extract the audio track from a video as a standalone audio file",
  "input": {
    "type": "video",
    "description": "Source video file"
  },
  "output": {
    "type": "audio",
    "description": "Extracted audio file"
  },
  "params": [
    {
      "name": "format",
      "type": "enum",
      "default": "wav",
      "options": ["wav", "mp3", "aac"],
      "description": "Output audio format"
    }
  ]
}
